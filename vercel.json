{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/amt-scan.ts": {
      "maxDuration": 60
    },
    "api/amt-checkout.ts": {
      "maxDuration": 30
    },
    "api/amt-welcome-mail.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
